# ===========================================
# CONFIGURACIÓN DE BASE DE DATOS MYSQL
# ===========================================
# Credenciales del contenedor MySQL
MYSQL_ROOT_PASSWORD=root123
MYSQL_DATABASE=veterinaria_db
MYSQL_USER=vet_user
MYSQL_PASSWORD=vet_pass123

# ===========================================
# CONFIGURACIÓN DE SPRING BOOT
# ===========================================
# Conexión a la base de datos
DB_HOST=mysql
DB_PORT=3306
DB_NAME=veterinaria_db
DB_USER=vet_user
DB_PASSWORD=vet_pass123

# Perfil de Spring (development, production)
SPRING_PROFILES_ACTIVE=production

# ===========================================
# SEGURIDAD Y AUTENTICACIÓN
# ===========================================
# Password inicial para usuarios (user/vet/admin)
# Estos usuarios se crean automáticamente en el primer arranque
SEED_PASSWORD=duoc2026

# JWT Secret Key (mínimo 32 caracteres)
# IMPORTANTE: Cambiar en producción
JWT_SECRET=clave-secreta-veterinaria-duoc-2026-seguridad-calidad-desarrollo

# JWT Expiration (en milisegundos, 3600000 = 1 hora)
JWT_EXPIRATION=3600000
